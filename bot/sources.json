{
  "sources": [
    {
      "name": "swissinfo",
      "type": "xml",
      "url": "https://cdn.prod.swi-services.ch/rss/eng/rssxml/top-news/rss",
      "language": "en",
      "channel": "german",
      "category": "swissinfo",
      "schema_file": "schemas/swissinfo.xsd",
      "mapping": {
        "items": "channel/item",
        "id": "guid",
        "title": "title",
        "lead": "description",
        "url": "link",
        "image": "enclosure@url",
        "published": "pubDate",
        "published_format": "rfc822",
        "category": "category"
      }
    },
    {
      "name": "blick",
      "type": "xml",
      "url": "https://www.blick.ch/schweiz/rss.xml",
      "language": "de",
      "channel": "german",
      "category": "blick",
      "schema_file": "schemas/blick.xsd",
      "mapping": {
        "items": "channel/item",
        "id": "guid",
        "id_pattern": "id(\\d+)\\.html",
        "title": "title",
        "lead": "description",
        "url": "link",
        "published": "pubDate",
        "published_format": "rfc822"
      }
    },
    {
      "name": "guardian-world",
      "type": "xml",
      "url": "https://www.theguardian.com/world/rss",
      "language": "en",
      "channel": "english",
      "category": "guardian_world",
      "namespaces": {"media": "http://search.yahoo.com/mrss/"},
      "schema_file": "schemas/guardian-world.xsd",
      "mapping": {
        "items": "channel/item",
        "id": "guid",
        "title": "title",
        "lead": "description",
        "lead_html": true,
        "lead_remove": ["Continue reading\\.{3}\\s*$"],
        "url": "link",
        "image": ["media:content[@width='700']@url", "media:content@url"],
        "published": "pubDate",
        "published_format": "rfc822",
        "category": "category"
      }
    },
    {
      "name": "bbc-world",
      "type": "xml",
      "url": "https://feeds.bbci.co.uk/news/world/rss.xml",
      "language": "en",
      "channel": "english",
      "category": "bbc_world",
      "namespaces": {"media": "http://search.yahoo.com/mrss/"},
      "schema_file": "schemas/bbc-world.xsd",
      "mapping": {
        "items": "channel/item",
        "id": "guid",
        "title": "title",
        "lead": "description",
        "url": "link",
        "image": "media:thumbnail@url",
        "published": "pubDate",
        "published_format": "rfc822"
      }
    }
  ]
