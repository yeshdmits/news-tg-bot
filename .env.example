# --- Required ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Channel ID (e.g. @mychannel or -1001234567890); bot must be channel admin
TELEGRAM_CHANNEL_ID=
# DeepL API key (free tier: 500K chars/month)
DEEPL_API_KEY=

# --- Optional (defaults shown) ---
# How often to check for new articles
#POLL_INTERVAL_MINUTES=30
# Articles requested per API time window (1h/6h/24h)
#NEWS_FETCH_LIMIT=10
# SQLite database path
#DB_PATH=data/posted.db
# Translate the article lead too (false = titles only, ~4x less DeepL usage)
#TRANSLATE_LEAD=true
# Truncate leads to this length before translating/posting
#LEAD_MAX_CHARS=300
# Cap on posts per polling cycle (protects against flooding the channel)
#MAX_POSTS_PER_CYCLE=5
# On very first run, mark current articles as seen instead of posting them all
#SKIP_INITIAL_BACKLOG=true
# Comma-separated categories to skip, matched by prefix (e.g. "sport" also
# skips sport/wm-2026-in-usa). Use the category path as seen in article URLs.
# Ignored when INCLUDE_CATEGORIES is set.
#SKIP_CATEGORIES=
# Comma-separated categories to post EXCLUSIVELY (same format as above).
# When set, only these categories are posted and SKIP_CATEGORIES is ignored.
# Empty = all categories.
#INCLUDE_CATEGORIES=
# How posts are displayed: photo_full (image + title + lead),
# photo_short (image + title), text_full (title + lead), text_short (title)
#POST_STYLE=photo_full
